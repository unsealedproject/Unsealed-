# Example environment file — DO NOT commit real keys.
#
# On production, this file lives OUTSIDE the webroot at:
#   /etc/fca/api_keys.env       (mode 600, owner root)
#
# It's loaded by api_keys.php at runtime. Keys here are used for
# server-side proxy calls to third-party services so the user's browser
# never sees them and never hits those services directly.

# Anthropic (Claude Vision + text) — used by api_ai.php, api_order_verify.php
ANTHROPIC_API_KEY=sk-ant-...

# Congress.gov v3 — used by api_congress.php
CONGRESS_API_KEY=...

# FEC OpenFEC v1 — used by api_fec.php
FEC_API_KEY=...

# OpenStates v3 — used by api_openstates.php
OPENSTATES_API_KEY=...

# FollowTheMoney (NIMP) — used by api_ftm.php for state judicial
# campaign finance (FEC only covers federal)
FTM_API_KEY=...

# Optional: CourtListener token for api_courtlistener.php
# (unauthenticated calls work but are rate-limited more aggressively)
COURTLISTENER_TOKEN=...
